# Copy to .env (gitignored) and fill in. Only needed for the one-off admin
# scripts (db:apply, art:upload), never shipped to the client.

# For scripts/apply-sql.mjs — applies the schema + seed to the shared DB.
# Get it from: Supabase dashboard → Project Settings → Database → Database password
# (or paste a full DATABASE_URL instead, which takes precedence).
SUPABASE_DB_PASSWORD=
# DATABASE_URL=postgresql://postgres.snlrpqamjzwoksmoxzir:<password>@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# For scripts/upload-art.mjs — uploads card art to the tarot-card-art bucket.
# Get it from: Supabase dashboard → Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=
